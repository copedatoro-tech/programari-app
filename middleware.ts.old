import { createMiddlewareClient } from '@supabase/auth-helpers-nextjs'
import { NextResponse } from 'next/server'
import type { NextRequest } from 'next/server'

export async function middleware(req: NextRequest) {
  const res = NextResponse.next()
  const supabase = createMiddlewareClient({ req, res })

  const { pathname } = req.nextUrl

  // 1. DEFINIM EXCEPȚIILE (Pagini accesibile fără login)
  const isPublicPage = 
    pathname === '/login' || 
    pathname === '/register' || 
    pathname === '/forgot-password' ||
    pathname.startsWith('/rezervare') || // Permite accesul clienților la calendar
    pathname.startsWith('/_next') || 
    pathname.startsWith('/api/auth') || // Necesar pentru procesul de login
    pathname.match(/\.(png|jpg|jpeg|svg|gif|ico)$/); // Permite încărcarea imaginilor/logo-ului

  // 2. VERIFICĂM SESIUNEA
  const { data: { session } } = await supabase.auth.getSession()

  // 3. LOGICA DE REDIRECȚIONARE
  // Dacă NU este pagină publică și NU avem sesiune -> trimitem la login
  if (!isPublicPage && !session) {
    return NextResponse.redirect(new URL('/login', req.url))
  }

  // Dacă ești logat și încerci să intri pe Login, te trimitem în Dashboard
  if (session && (pathname === '/login' || pathname === '/register')) {
    return NextResponse.redirect(new URL('/programari', req.url))
  }

  return res
}

export const config = {
  matcher: [
    /*
     * Se aplică pe toate rutele, cu excepția fișierelor statice interne Next.js
     */
    '/((?!_next/static|_next/image|favicon.ico).*)',
  ],
}