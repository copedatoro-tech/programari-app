import { createMiddlewareClient } from '@supabase/auth-helpers-nextjs'
import { NextResponse } from 'next/server'
import type { NextRequest } from 'next/server'

export async function middleware(req: NextRequest) {
  const res = NextResponse.next()
  const supabase = createMiddlewareClient({ req, res })

  const { pathname } = req.nextUrl

  // DEFINIM EXCEPȚIILE (Pagini care trebuie să fie accesibile FĂRĂ LOGIN)
  const isPublicPage = 
    pathname === '/login' || 
    pathname === '/register' || 
    pathname === '/forgot-password' ||
    pathname === '/settings' || 
    pathname === '/rezervare' || // <--- AM ADĂUGAT RUTA DE REZERVARE
    pathname.startsWith('/rezervare') || // Pentru a permite și parametri gen ?id=...
    pathname.startsWith('/_next') || 
    pathname.includes('/api/') ||
    pathname.endsWith('.png') || // Permitem logo-ul să se încarce
    pathname.endsWith('.jpg') ||
    pathname.endsWith('.svg');

  // Verificăm sesiunea DOAR dacă nu este pagină publică
  if (!isPublicPage) {
    const { data: { session } } = await supabase.auth.getSession()
    if (!session) {
      return NextResponse.redirect(new URL('/login', req.url))
    }
  }

  return res
}

export const config = {
  matcher: [
    '/((?!_next/static|_next/image|favicon.ico).*)',
  ],
}